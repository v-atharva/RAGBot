# Copy to .env and fill in. .env is gitignored.

# --- LLM provider ---
# Local-first: Ollama for the demo. Switch to a hosted model later by setting
# LLM_PROVIDER=anthropic and providing LLM_API_KEY — no code changes needed.
LLM_PROVIDER=ollama
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen3.5:9b

# Hosted backend (only used when LLM_PROVIDER=anthropic).
LLM_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-5

# Local paths to course materials (not committed).
TRANSCRIPTS_DIR=transcripts
MATERIALS_DIR=misccontext/raw

# Where the built indexes live.
INDEX_DIR=data/index

# Local embedding model (sentence-transformers). No API key needed.
EMBED_MODEL=BAAI/bge-small-en-v1.5

# Virtualized "now" for timeline-aware features (the reference course is historical).
# Leave empty to use the real current time. Example: 2026-07-15T09:00:00
MOCK_NOW=
